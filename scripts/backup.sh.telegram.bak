#!/usr/bin/env bash
set -euo pipefail

BACKUP_DIR="/var/backups/nuran"
TIMESTAMP="$(date +%Y%m%d_%H%M%S)"
BACKUP_FILE="${BACKUP_DIR}/nuran_${TIMESTAMP}.sql.gz"

S3_BUCKET="30dd63ad-b8ad-48a9-9fb7-c545973fac8d"
S3_PREFIX="nuran/db"
S3_ENDPOINT="https://s3.twcstorage.ru"

cd "$(dirname "${BASH_SOURCE[0]}")/.."

if [ ! -f ".env" ]; then
  echo "Error: .env file not found at repo root. Create it from .env.example before running backups." >&2
  exit 1
fi

set -a
# shellcheck disable=SC1091
source .env
set +a

mkdir -p "${BACKUP_DIR}"

echo "Creating PostgreSQL backup at ${BACKUP_FILE} ..."
docker compose -f infra/docker-compose.yml exec -T db \
  pg_dump -U "${POSTGRES_USER:-${DB_USER:-postgres}}" "${POSTGRES_DB:-${DB_NAME:-nuran}}" \
  | gzip > "${BACKUP_FILE}"

if [ ! -s "${BACKUP_FILE}" ]; then
  echo "Error: Backup file is missing or empty." >&2
  exit 1
fi

echo "Backup created."
echo "Backup OK: ${BACKUP_FILE}"

echo "Uploading backup to S3..."
aws s3 cp "${BACKUP_FILE}" \
  "s3://${S3_BUCKET}/${S3_PREFIX}/$(basename "${BACKUP_FILE}")" \
  --endpoint-url "${S3_ENDPOINT}"

echo "Verifying S3 upload..."
aws s3 ls \
  "s3://${S3_BUCKET}/${S3_PREFIX}/$(basename "${BACKUP_FILE}")" \
  --endpoint-url "${S3_ENDPOINT}"

echo "Rotating local backups, keeping the 7 most recent..."
ls -1t "${BACKUP_DIR}"/nuran_*.sql.gz 2>/dev/null | tail -n +8 | xargs -r rm --

echo "Done."
