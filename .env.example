# Django settings
SECRET_KEY=change-me-in-production
DEBUG=0

# Comma-separated list; used by Django ALLOWED_HOSTS
ALLOWED_HOSTS=localhost,127.0.0.1,nuranpark.com
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,nuranpark.com

# Comma-separated list of fully-qualified origins
DJANGO_CSRF_TRUSTED_ORIGINS=https://nuranpark.com

# Database configuration (Django)
DB_ENGINE=postgresql
DB_NAME=nuran
DB_USER=nuran
DB_PASSWORD=change-me
DB_HOST=db
DB_PORT=5432

# PostgreSQL container configuration
POSTGRES_DB=nuran
POSTGRES_USER=nuran
POSTGRES_PASSWORD=change-me

# Redis (optional, for cache/broker)
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0

# CORS (optional, overrides local defaults when set)
CORS_ALLOWED_ORIGINS=https://nuranpark.com

# Frontend API base (used in axios instance)
VITE_API_BASE=/api/v1
# For local dev you can use instead:
# VITE_API_URL=http://localhost:8000/api/v1

# Auto-deploy webhook (GitHub): secret for X-Hub-Signature-256 or X-Deploy-Token. Do not commit real value.
WEBHOOK_SECRET=change-me-webhook-secret

# Nginx config mode: http.conf (default, no certs) or ssl.conf (HTTPS with Let's Encrypt certs)
# NGINX_CONF_TARGET=http.conf

